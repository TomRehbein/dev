#!/usr/bin/env bash

set -e

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
filters=()
dry="0"

while [[ $# > 0 ]]; do
	if [[ $1 == "--dry" ]]; then
		dry="1"
	else
		filters+=("$1")
	fi
	shift
done

log() {
	if [[ $dry == "1" ]]; then
		echo "[DRY_RUN]: $@"
	else
		echo "$@"
	fi
}

execute() {
	log "execute $@"
	if [[ $dry == "1" ]]; then
		return
	fi
	"$@"
}

log "$script_dir -- filters: ${filters[*]}"

cd "$script_dir"
scripts=$(find ./runs -maxdepth 1 -mindepth 1 -type f -perm /111 | sort)

for script in $scripts; do
	if [ ${#filters[@]} -gt 0 ]; then
		match=false
		for f in "${filters[@]}"; do
			echo "$script" | grep -q "$f" && match=true && break
		done
		if ! $match; then
			log "filtering $script"
			continue
		fi
	fi

	execute ./$script
done
