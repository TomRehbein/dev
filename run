#!/usr/bin/env bash

set -euo pipefail

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
# shellcheck source=lib/os.sh
source "$script_dir/lib/os.sh"
require_os arch
filters=()
dry="0"

while [[ $# > 0 ]]; do
	if [[ $1 == "--dry" ]]; then
		dry="1"
	else
		filters+=("$1")
	fi
	shift
done

log() {
	if [[ $dry == "1" ]]; then
		echo "[DRY_RUN]: $@"
	else
		echo "$@"
	fi
}

execute() {
	log "execute $@"
	if [[ $dry == "1" ]]; then
		return
	fi
	"$@"
}

# ${arr[*]:-} keeps `set -u` happy when no filters were passed (empty array).
log "$script_dir -- filters: ${filters[*]:-}"

cd "$script_dir"
# `-perm -u+x` is portable across GNU and BSD find (`-executable` is GNU-only).
scripts=$(find ./runs -maxdepth 1 -mindepth 1 -type f -perm -u+x | sort)

for script in $scripts; do
	if [ ${#filters[@]} -gt 0 ]; then
		match=false
		for f in "${filters[@]}"; do
			echo "$script" | grep -q "$f" && match=true && break
		done
		if ! $match; then
			log "filtering $script"
			continue
		fi
	fi

	execute ./$script
done
