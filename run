#!/usr/bin/env bash

set -e

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
filters=()
dry="0"

while [[ $# -gt 0 ]]; do
	if [[ $1 == "--dry" ]]; then
		dry="1"
	else
		filters+=("$1")
	fi
	shift
done

log() {
	if [[ $dry == "1" ]]; then
		echo "[DRY_RUN]: $@"
	else
		echo "$@"
	fi
}

execute() {
	log "execute $@"
	if [[ $dry == "1" ]]; then
		return
	fi
	"$@"
}

# Installers add to ~/.bash_profile / ~/.bashrc but can't export back to this
# shell. Re-check known locations after each script so subsequent scripts (and
# 99-checks) find freshly installed tools by plain name.
_refresh_path() {
	local dirs=(
		"$HOME/.bun/bin"
		"$HOME/.local/bin"
		"$HOME/.cargo/bin"
		"$HOME/.opencode/bin"
		"$HOME/.pyenv/bin"
	)
	for d in "${dirs[@]}"; do
		case ":${PATH}:" in
			*":${d}:"*) ;;
			*) if [[ -d "$d" ]]; then export PATH="${d}:${PATH}"; fi ;;
		esac
	done
}

log "$script_dir -- filters: ${filters[*]}"

cd "$script_dir"
scripts=$(find ./runs -maxdepth 1 -mindepth 1 -executable -type f | sort)

for script in $scripts; do
	if [ ${#filters[@]} -gt 0 ]; then
		match=false
		for f in "${filters[@]}"; do
			echo "$script" | grep -q "$f" && match=true && break
		done
		if ! $match; then
			log "filtering $script"
			continue
		fi
	fi

	execute "$script"
	_refresh_path
done
