#!/usr/bin/env bash

set -euo pipefail

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
# shellcheck source=../lib/os.sh
source "$script_dir/../lib/os.sh"
require_os arch

if command -v oh-my-posh &> /dev/null; then
    echo "oh-my-posh already installed: $(oh-my-posh --version)"
else
    mkdir -p "$HOME/.local/bin"

    pkg_install unzip

    curl -s https://ohmyposh.dev/install.sh | bash -s -- -d "$HOME/.local/bin"

    export PATH="$HOME/.local/bin:$PATH"
    # Font installation requires a display/font subsystem — skip in CI.
    [ -n "${CI:-}" ] || oh-my-posh font install meslo
fi

# Deploy theme file — runs/ executes before dev-env, so the theme must be
# copied here to be available at first shell startup.
mkdir -p "$HOME/.config/omp"
cp "$script_dir/../env/.config/omp/the-unnamed.omp.json" "$HOME/.config/omp/the-unnamed.omp.json"
echo "oh-my-posh theme deployed: ~/.config/omp/the-unnamed.omp.json"
