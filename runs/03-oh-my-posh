#!/usr/bin/env bash

set -e

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

# Check for the Linux binary explicitly — on WSL, oh-my-posh.exe may be
# reachable via the Windows PATH and fool a plain `command -v` check.
if [ -x "$HOME/.local/bin/oh-my-posh" ]; then
    echo "oh-my-posh already installed: $("$HOME/.local/bin/oh-my-posh" --version)"
else
    mkdir -p "$HOME/.local/bin"

    sudo apt install unzip -y

    curl -s https://ohmyposh.dev/install.sh | bash -s -- -d "$HOME/.local/bin"

    export PATH="$HOME/.local/bin:$PATH"
    oh-my-posh font install meslo
fi

# Deploy theme file — runs/ executes before dev-env, so the theme must be
# copied here to be available at first shell startup.
mkdir -p "$HOME/.config/omp"
cp "$script_dir/../env/.config/omp/the-unnamed.omp.json" "$HOME/.config/omp/the-unnamed.omp.json"
echo "oh-my-posh theme deployed: ~/.config/omp/the-unnamed.omp.json"
