#!/usr/bin/env bash

set -e

# Check for the Linux binary explicitly — on WSL, opencode.exe may be
# reachable via the Windows PATH and fool a plain `command -v` check.
if [ -x "$HOME/.local/bin/opencode" ]; then
    echo "opencode already installed: $("$HOME/.local/bin/opencode" --version 2>/dev/null || echo 'unknown version')"
    exit 0
fi

export PATH="$HOME/.local/bin:$PATH"

curl -fsSL https://opencode.ai/install | bash
