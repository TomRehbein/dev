#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/os.sh
source "$SCRIPT_DIR/../lib/os.sh"
require_os macos

if command -v opencode &> /dev/null; then
    echo "opencode already installed: $(opencode --version 2>/dev/null || echo 'unknown version')"
    exit 0
fi

mkdir -p "$HOME/.local/bin"
export PATH="$HOME/.local/bin:$PATH"

# The -d flag is no longer supported by the installer; omit it.
# opencode's API is occasionally unreachable from CI runners — treat as
# non-fatal so the pipeline doesn't fail on a transient network issue.
if ! curl -fsSL https://opencode.ai/install | bash; then
    echo "⚠️  opencode install failed (API unreachable?) — skipping"
fi
