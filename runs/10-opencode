#!/usr/bin/env bash

set -e

# Check for the native binary explicitly — on WSL, opencode.exe may be
# reachable via the Windows PATH and fool a plain `command -v` check.
if [ -x "$HOME/.local/bin/opencode" ] || [ -x "$HOME/.opencode/bin/opencode" ]; then
    echo "opencode already installed: $(opencode --version 2>/dev/null || echo 'unknown version')"
    exit 0
fi

mkdir -p "$HOME/.local/bin"
export PATH="$HOME/.local/bin:$PATH"

curl -fsSL https://opencode.ai/install | bash -s -- -d "$HOME/.local/bin"
