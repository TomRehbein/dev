#!/usr/bin/env bash

set -e

# Check for the Linux binary explicitly — on WSL, opencode.exe may be
# reachable via the Windows PATH and fool a plain `command -v` check.
# The installer no longer supports -d and defaults to ~/.opencode/bin;
# also accept ~/.local/bin for pre-existing installs.
for bin in "$HOME/.opencode/bin/opencode" "$HOME/.local/bin/opencode"; do
    if [ -x "$bin" ]; then
        echo "opencode already installed: $("$bin" --version 2>/dev/null || echo 'unknown version')"
        exit 0
    fi
done

# opencode's API is occasionally unreachable from CI runners — treat as
# non-fatal so the pipeline doesn't fail on a transient network issue.
if ! curl -fsSL https://opencode.ai/install | bash; then
    echo "⚠️  opencode install failed (API unreachable?) — skipping"
fi
