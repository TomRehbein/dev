#!/usr/bin/env bash

# nvm.sh references unset variables internally, so `set -u` is intentionally
# omitted here (would abort on sourcing nvm.sh).
set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/os.sh
source "$SCRIPT_DIR/../lib/os.sh"
require_os arch

export NVM_DIR="$HOME/.nvm"

if [ -s "$NVM_DIR/nvm.sh" ]; then
    \. "$NVM_DIR/nvm.sh"
    echo "nvm already installed: $(nvm --version)"
    exit 0
fi

mkdir -p "$NVM_DIR"

# GitHub API may be rate-limited in CI; fall back to known-good version.
NVM_LATEST=$(curl -fsSL "https://api.github.com/repos/nvm-sh/nvm/releases/latest" | grep '"tag_name"' | cut -d'"' -f4) || NVM_LATEST="v0.40.3"
curl -o- "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_LATEST}/install.sh" | bash

if [ -s "$NVM_DIR/nvm.sh" ]; then \. "$NVM_DIR/nvm.sh"; fi

nvm install --lts
nvm install node --latest-npm
nvm use node
