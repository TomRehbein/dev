#!/usr/bin/env bash

set -e

BREW_PACKAGES=(git ripgrep jq tldr tmux tree htop btop git-delta coreutils fzf)
missing_pkgs=()
for pkg in "${BREW_PACKAGES[@]}"; do
    brew list "$pkg" &>/dev/null || missing_pkgs+=("$pkg")
done

if [ ${#missing_pkgs[@]} -gt 0 ]; then
    echo "Installing missing brew packages: ${missing_pkgs[*]}"
    brew install "${missing_pkgs[@]}"
else
    echo "All brew packages already installed, skipping."
fi
