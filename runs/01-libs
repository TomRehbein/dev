#!/usr/bin/env bash

set -e

sudo apt -y update
sudo apt -y install git ripgrep jq tldr unzip build-essential tmux tree htop btop git-delta

if [ ! -d "$HOME/personal/fzf" ]; then
    git clone https://github.com/junegunn/fzf.git "$HOME/personal/fzf"
fi

if ! command -v fzf &>/dev/null; then
    "$HOME/personal/fzf/install" --all
fi
