#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/os.sh
source "$SCRIPT_DIR/../lib/os.sh"
require_os arch

# build-essential maps to the base-devel group on Arch (compiler toolchain),
# installed by install.sh as a precondition. lldb and git-delta live in the
# official repos. tealdeer provides the `tldr` command (the Rust client) and
# replaces Ubuntu's node-based tldr — no AUR needed.
PACMAN_PACKAGES=(git ripgrep jq tealdeer unzip tmux tree htop btop git-delta lldb)
pkg_install "${PACMAN_PACKAGES[@]}"

if [ ! -d "$HOME/personal/fzf" ]; then
    git clone https://github.com/junegunn/fzf.git "$HOME/personal/fzf"
fi

if [ ! -x "$HOME/personal/fzf/bin/fzf" ]; then
    "$HOME/personal/fzf/install" --all
else
    echo "fzf already installed: $("$HOME/personal/fzf/bin/fzf" --version)"
fi
