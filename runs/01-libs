#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/os.sh
source "$SCRIPT_DIR/../lib/os.sh"
require_os macos

# build-essential and lldb are not Homebrew formulae on macOS — they ship with
# the Xcode Command Line Tools, which install.sh installs as a precondition.
# git also comes from the CLT but is listed so brew keeps it up to date.
BREW_PACKAGES=(git ripgrep jq tldr unzip tmux tree htop btop git-delta)
pkg_install "${BREW_PACKAGES[@]}"

if [ ! -d "$HOME/personal/fzf" ]; then
    git clone https://github.com/junegunn/fzf.git "$HOME/personal/fzf"
fi

if [ ! -x "$HOME/personal/fzf/bin/fzf" ]; then
    "$HOME/personal/fzf/install" --all
else
    echo "fzf already installed: $("$HOME/personal/fzf/bin/fzf" --version)"
fi
