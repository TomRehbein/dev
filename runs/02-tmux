#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v tmux &>/dev/null; then
    brew install tmux
else
    echo "tmux already installed: $(tmux -V)"
fi

TPM_DIR="$SCRIPT_DIR/../env/.config/tmux/plugins/tpm"

if [ ! -d "$TPM_DIR" ]; then
    git clone https://github.com/tmux-plugins/tpm "$TPM_DIR"
fi

mkdir -p ~/.config/tmux

export TMUX_PLUGIN_MANAGER_PATH="$SCRIPT_DIR/../env/.config/tmux/plugins"
"$TPM_DIR/bin/install_plugins"
