#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/os.sh
source "$SCRIPT_DIR/../lib/os.sh"
require_os arch

# Install target stays at /usr/local (Ubuntu parity); the default Arch prefix
# is /usr, which we leave to pacman's own neovim package. `make install` needs
# sudo for /usr/local.
NVIM_BIN="/usr/local/bin/nvim"

if [ -x "$NVIM_BIN" ]; then
    echo "neovim already installed: $("$NVIM_BIN" --version | head -1)"
    exit 0
fi

# Build deps. lua51 replaces Ubuntu's lua5.1 / liblua5.1-0-dev. The C toolchain
# comes from base-devel (install.sh).
pkg_install cmake gettext lua51

if [ ! -d "$HOME/personal/neovim" ]; then
    git clone https://github.com/neovim/neovim.git "$HOME/personal/neovim"
else
    git -C "$HOME/personal/neovim" pull --ff-only
fi

cd "$HOME/personal/neovim"
make CMAKE_BUILD_TYPE=RelWithDebInfo
sudo make install
