#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/os.sh
source "$SCRIPT_DIR/../lib/os.sh"
require_os macos

# @playwright/cli installs the binary as "playwright", not "playwright-cli".
if command -v playwright &> /dev/null; then
    echo "playwright already installed: $(playwright --version 2>/dev/null || echo 'unknown version')"
    exit 0
fi

# NVM does not export npm to PATH in non-interactive subshells — set it explicitly.
# Guard against the versions/node directory not existing yet (e.g. nvm not yet used).
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -d "$NVM_DIR/versions/node" ] && [ -n "$(ls "$NVM_DIR/versions/node" 2>/dev/null)" ]; then
    export PATH="$NVM_DIR/versions/node/$(ls "$NVM_DIR/versions/node" | sort -V | tail -1)/bin:$PATH"
fi

npm install -g playwright@latest
