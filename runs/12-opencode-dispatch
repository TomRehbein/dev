#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/os.sh
source "$SCRIPT_DIR/../lib/os.sh"
require_os arch

REPO_DIR="$HOME/personal/opencode-dispatch"

if [ -d "$REPO_DIR" ]; then
    echo "opencode-dispatch already exists at $REPO_DIR"
    exit 0
fi

git clone https://github.com/TomRehbein/opencode-dispatch "$REPO_DIR"

# bun's workspace runner spawns sub-processes that call `bun` by name,
# not via absolute path — export so they find it.
export PATH="$HOME/.bun/bin:$PATH"

cd "$REPO_DIR"
bun install
bun run build

cd "$REPO_DIR/packages/cli"
bun link
