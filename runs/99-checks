#!/usr/bin/env bash

set -euo pipefail

# ---------------------------------------------------------------------------
# 99-checks — verify that all dev-env tools are installed.
#
# Exit codes:
#   0 — all checks passed
#   1 — one or more checks failed
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/os.sh
source "$SCRIPT_DIR/../lib/os.sh"
require_os arch

# ./run launches non-login subshells — .bash_profile / .shell_common.sh are
# never sourced, so tool paths set up by the installers are absent. Add them
# here so the checks reflect the real post-login environment.
export PATH="$HOME/.local/bin:$HOME/.pyenv/bin:$HOME/.cargo/bin:$HOME/.bun/bin:$PATH"
NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -d "$NVM_DIR/versions/node" ]; then
    _node=$(ls "$NVM_DIR/versions/node" 2>/dev/null | sort -V | tail -1)
    [ -n "$_node" ] && export PATH="$NVM_DIR/versions/node/$_node/bin:$PATH"
    unset _node
fi

PASS=0
FAIL=0
WARN=0

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_ok() {
    local label="$1" detail="$2"
    printf "${GREEN}[OK]${RESET}   %-16s %s\n" "$label" "$detail"
    PASS=$(( PASS + 1 ))
}

_fail() {
    local label="$1" detail="$2"
    printf "${RED}[FAIL]${RESET} %-16s %s\n" "$label" "$detail"
    FAIL=$(( FAIL + 1 ))
}

_warn() {
    local label="$1" detail="$2"
    printf "${YELLOW}[WARN]${RESET} %-16s %s\n" "$label" "$detail"
    WARN=$(( WARN + 1 ))
}

# check_cmd LABEL [CMD]
#   Passes when 'command -v CMD' resolves. CMD defaults to LABEL.
check_cmd() {
    local label="$1" cmd="${2:-$1}"
    local resolved
    resolved="$(command -v "$cmd" 2>/dev/null || true)"
    if [ -z "$resolved" ]; then
        _fail "$label" "not found in PATH"
    else
        _ok "$label" "$resolved"
    fi
}

# check_pkg LABEL CMD [PKG]
#   Uses pkg_check (command -v with pacman -Q fallback) to confirm a tool.
check_pkg() {
    local label="$1" cmd="$2" pkg="${3:-$2}"
    if pkg_check "$cmd" "$pkg"; then
        local resolved
        resolved="$(command -v "$cmd" 2>/dev/null || true)"
        _ok "$label" "${resolved:-installed (pacman: $pkg)}"
    else
        _fail "$label" "not installed (pacman: $pkg)"
    fi
}

# check_file LABEL PATH [description]
check_file() {
    local label="$1" path="$2" desc="${3:-$2}"
    if [ -e "$path" ]; then
        _ok "$label" "$desc"
    else
        _fail "$label" "not found: $path"
    fi
}

# ---------------------------------------------------------------------------
# Checks
# ---------------------------------------------------------------------------

echo ""
printf "${BOLD}Checking dev environment (Arch Linux)${RESET}\n"
printf '%0.s─' {1..50}
echo ""
echo ""

# --- pacman packages (01-libs, 02-tmux) ------------------------------------
echo "  pacman packages"
check_pkg "git"     "git"
check_pkg "rg"      "rg"    "ripgrep"
check_pkg "jq"      "jq"
check_pkg "delta"   "delta" "git-delta"
check_pkg "tldr"    "tldr"  "tealdeer"
check_pkg "unzip"   "unzip"
check_pkg "tree"    "tree"
check_pkg "htop"    "htop"
check_pkg "btop"    "btop"
check_pkg "tmux"    "tmux"

echo ""

# --- build toolchain (base-devel / lldb; replaces build-essential) ---------
echo "  build toolchain"
# base-devel is a metapackage since Arch 2022 — use -Q (not -Qg group query).
if pacman -Q base-devel &>/dev/null; then
    _ok "base-devel" "installed"
else
    _fail "base-devel" "not installed (run: sudo pacman -S base-devel)"
fi
check_cmd "lldb"

echo ""

# --- installer-based binaries ($HOME/.local/bin, etc.) ---------------------
echo "  installer binaries"
check_cmd "oh-my-posh"
check_cmd "opencode"
check_cmd "claude"
check_cmd "bun"
check_cmd "uv"
check_cmd "rustup"
check_cmd "cargo"
check_cmd "nvim"

echo ""

# --- version managers & their shims ----------------------------------------
echo "  version managers"

# nvm — shell function, no binary; check the nvm.sh loader
check_file "nvm" "$HOME/.nvm/nvm.sh" "$HOME/.nvm/nvm.sh"

check_cmd "node"
check_cmd "npm"
check_cmd "pyenv"
check_cmd "python"
check_cmd "fzf"

echo ""

# --- npm globals (13-playwright-cli) ----------------------------------------
echo "  npm globals"
# @playwright/cli registers the binary as "playwright", not "playwright-cli".
check_cmd "playwright"

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
TOTAL=$(( PASS + FAIL + WARN ))
echo ""
printf '%0.s─' {1..50}
echo ""

if [ "$FAIL" -eq 0 ] && [ "$WARN" -eq 0 ]; then
    printf "${GREEN}${BOLD}All $TOTAL checks passed.${RESET}\n"
elif [ "$FAIL" -eq 0 ]; then
    printf "${YELLOW}${BOLD}${PASS}/${TOTAL} checks passed, ${WARN} warning(s).${RESET}\n"
else
    printf "${RED}${BOLD}${PASS}/${TOTAL} checks passed — ${FAIL} failed, ${WARN} warning(s).${RESET}\n"
fi
echo ""

[ "$FAIL" -eq 0 ]
