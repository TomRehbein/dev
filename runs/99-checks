#!/usr/bin/env bash

set -e

# ---------------------------------------------------------------------------
# 99-checks — verify that all dev-env tools are installed (macOS).
#
# Exit codes:
#   0 — all checks passed
#   1 — one or more checks failed
# ---------------------------------------------------------------------------

PASS=0
FAIL=0
WARN=0

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_ok() {
    local label="$1" detail="$2"
    printf "${GREEN}[OK]${RESET}   %-16s %s\n" "$label" "$detail"
    PASS=$(( PASS + 1 ))
}

_fail() {
    local label="$1" detail="$2"
    printf "${RED}[FAIL]${RESET} %-16s %s\n" "$label" "$detail"
    FAIL=$(( FAIL + 1 ))
}

_warn() {
    local label="$1" detail="$2"
    printf "${YELLOW}[WARN]${RESET} %-16s %s\n" "$label" "$detail"
    WARN=$(( WARN + 1 ))
}

# check_cmd LABEL [COMMAND]
#   Passes when the command is found via `command -v`.
check_cmd() {
    local label="$1" cmd="${2:-$1}"
    local resolved
    resolved="$(command -v "$cmd" 2>/dev/null || true)"
    if [ -n "$resolved" ]; then
        _ok "$label" "$resolved"
    else
        _fail "$label" "not found in PATH"
    fi
}

# check_pkg LABEL PACKAGE [COMMAND]
#   Uses `brew list` to confirm the package is installed.
#   Falls back to PATH check for tools that ship with macOS/Xcode CLT.
check_pkg() {
    local label="$1" pkg="$2" cmd="${3:-$1}"
    if brew list "$pkg" &>/dev/null 2>&1; then
        local resolved
        resolved="$(command -v "$cmd" 2>/dev/null || true)"
        _ok "$label" "${resolved:-installed via brew}"
    else
        # Some tools (git, unzip, lldb) ship with macOS/Xcode CLT — fall back to PATH check
        local resolved
        resolved="$(command -v "$cmd" 2>/dev/null || true)"
        if [ -n "$resolved" ]; then
            _ok "$label" "$resolved (system)"
        else
            _fail "$label" "not installed (brew: $pkg)"
        fi
    fi
}

# check_bin LABEL PATH
#   Passes when the given path is an executable file.
check_bin() {
    local label="$1" path="$2"
    if [ -x "$path" ]; then
        _ok "$label" "$path"
    else
        _fail "$label" "not installed ($path not found)"
    fi
}

# check_file LABEL PATH [description]
#   Passes when PATH exists (file or directory).
check_file() {
    local label="$1" path="$2" desc="${3:-$2}"
    if [ -e "$path" ]; then
        _ok "$label" "$desc"
    else
        _fail "$label" "not found: $path"
    fi
}

# ---------------------------------------------------------------------------
# Version sort: use gsort on macOS (coreutils), fall back to sort -V.
# ---------------------------------------------------------------------------
_sort_v() { command -v gsort &>/dev/null && gsort -V || sort -V; }

# ---------------------------------------------------------------------------
# Latest nvm node version helper
# ---------------------------------------------------------------------------
_nvm_latest_node() {
    local nvm_versions_dir="$HOME/.nvm/versions/node"
    if [ -d "$nvm_versions_dir" ]; then
        ls "$nvm_versions_dir" 2>/dev/null | _sort_v | tail -1
    fi
}

# ---------------------------------------------------------------------------
# Checks
# ---------------------------------------------------------------------------

echo ""
printf "${BOLD}Checking dev environment (macOS)${RESET}\n"
printf '%0.s─' {1..50}
echo ""
echo ""

# --- system packages (01-libs) ---------------------------------------------
echo "  system packages"
check_pkg "git"       "git"
check_pkg "rg"        "ripgrep"    "rg"
check_pkg "jq"        "jq"
check_pkg "delta"     "git-delta"  "delta"
check_pkg "tldr"      "tldr"
check_pkg "tree"      "tree"
check_pkg "htop"      "htop"
check_pkg "btop"      "btop"
check_pkg "tmux"      "tmux"
check_pkg "fzf"       "fzf"
check_pkg "coreutils" "coreutils"  "gsort"
# unzip and lldb ship with macOS/Xcode CLT
check_cmd "unzip"
check_cmd "lldb"
echo ""

# --- explicit binaries -----------------------------------------------------
echo "  standalone binaries"
check_cmd "oh-my-posh"
check_cmd "nvim"
check_bin "opencode"  "$HOME/.opencode/bin/opencode"
check_bin "claude"    "$HOME/.local/bin/claude"
check_bin "bun"       "$HOME/.bun/bin/bun"
check_bin "uv"        "$HOME/.local/bin/uv"
check_bin "rustup"    "$HOME/.cargo/bin/rustup"
check_bin "cargo"     "$HOME/.cargo/bin/cargo"
echo ""

# --- version managers & their shims ----------------------------------------
echo "  version managers"

# nvm — shell function, no binary; check the nvm.sh loader
check_file "nvm" "$HOME/.nvm/nvm.sh" "$HOME/.nvm/nvm.sh"

# node/npm via nvm
NVM_NODE_VERSION="$(_nvm_latest_node)"
if [ -n "$NVM_NODE_VERSION" ]; then
    NVM_BIN="$HOME/.nvm/versions/node/${NVM_NODE_VERSION}/bin"
    check_bin "node" "$NVM_BIN/node"
    check_bin "npm"  "$NVM_BIN/npm"
else
    _fail "node" "no nvm node versions found under $HOME/.nvm/versions/node"
    _fail "npm"  "no nvm node versions found under $HOME/.nvm/versions/node"
    FAIL=$(( FAIL + 2 ))
fi

# pyenv
check_bin  "pyenv"  "$HOME/.pyenv/bin/pyenv"
check_file "python" "$HOME/.pyenv/shims/python" "$HOME/.pyenv/shims/python (pyenv shim)"

echo ""

# --- npm globals (13-playwright-cli) ----------------------------------------
echo "  npm globals"

if [ -n "$NVM_NODE_VERSION" ]; then
    check_bin "playwright-cli" "$HOME/.nvm/versions/node/${NVM_NODE_VERSION}/bin/playwright-cli"
else
    _fail "playwright-cli" "cannot check — no nvm node version found"
    FAIL=$(( FAIL + 1 ))
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
TOTAL=$(( PASS + FAIL + WARN ))
echo ""
printf '%0.s─' {1..50}
echo ""

if [ "$FAIL" -eq 0 ] && [ "$WARN" -eq 0 ]; then
    printf "${GREEN}${BOLD}All $TOTAL checks passed.${RESET}\n"
elif [ "$FAIL" -eq 0 ]; then
    printf "${YELLOW}${BOLD}${PASS}/${TOTAL} checks passed, ${WARN} warning(s).${RESET}\n"
else
    printf "${RED}${BOLD}${PASS}/${TOTAL} checks passed — ${FAIL} failed, ${WARN} warning(s).${RESET}\n"
fi
echo ""

[ "$FAIL" -eq 0 ]
